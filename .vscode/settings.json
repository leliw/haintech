{
    "python.testing.pytestArgs": [
        "tests",
        "--cov=haintech",
        // "--log-file=tests.log",
        "--log-format=%(asctime)s %(thread)d %(levelname)s %(name)s: %(message)s",
        "--log-date-format=%H:%M:%S.%f",
        // "--color=yes",
        "-rfE",
        "--no-cov-on-fail",
        "--disable-warnings",
        "--show-capture=log",
        "--show-capture=stdout",
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "workbench.preferredLightColorTheme": "Solarized Light",
    "workbench.preferredDarkColorTheme": "Solarized Dark",
    "debugpy.debugJustMyCode": false,
    "window.autoDetectColorScheme": true,
    "ruff.lineLength": 120,
    "files.exclude": {
        "**/.pytest_cache/": true,
        "**/__pycache__/": true,
        "**/.ruff_cache/": true,
        "**/*.egg-info/": true,
        "**/.venv/": true,
        "**/.vscode/": true,
        "**/.coverage/": true,
        "**/uv.lock/": true,
        "**/.python-version/": true,
        "dist/**": true,
    }
}
